<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="AvaloniaUI.Pages._HomePage.HomePage_SidePanel"
  xmlns:Prop="clr-namespace:AvaloniaUI.Pages._HomePage.WallpaperProperties">

  <StackPanel Spacing="5" Margin="10">

    <Label FontSize="16">Display</Label>
    <Prop:HomePage_WallpaperProperties_Combo x:Name="prop_Scaling"/>
    <Prop:HomePage_WallpaperProperties_Combo x:Name="prop_Clamp"/>
    <Prop:HomePage_WallpaperProperties_Slider x:Name="prop_OffsetX"/>
    <Prop:HomePage_WallpaperProperties_Slider x:Name="prop_OffsetY"/>

    <Grid Height="2" Margin="0 10" Background="rgb(34, 34, 40)"/>

    <Label FontSize="16">Colouring</Label>
    <Prop:HomePage_WallpaperProperties_Colour x:Name="prop_BGColour"/>
    <Prop:HomePage_WallpaperProperties_Slider x:Name="prop_Contrast"/>
    <Prop:HomePage_WallpaperProperties_Slider x:Name="prop_Saturation"/>

    <StackPanel x:Name="cont_SidePanel_CustomPropertiesGroup" Spacing="5">
      <Grid Height="2" Margin="0 10" Background="rgb(34, 34, 40)"/>

      <Label FontSize="16">Wallpaper Properties</Label>
      <StackPanel Spacing="5" x:Name="cont_SidePanel_CustomProperties"/>
    </StackPanel>

  </StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="AvaloniaUI.Pages.SteamWorkshopPage"
  xmlns:Common="clr-namespace:AvaloniaUI.Pages.Common">
  <Grid ColumnDefinitions="* Auto">
    <Grid RowDefinitions="150 *">
      <Common:FilterContainer x:Name="Filters"/>
      <ScrollViewer Grid.Row="1">
        <Common:Common_ItemFormatter_Paginated x:Name="ItemViewer"/>
      </ScrollViewer>
    </Grid>

    <Common:Common_Sidebar Grid.Column="1" x:Name="Sidebar"/>
  </Grid>
</UserControl>
<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="200" x:Class="AvaloniaUI.Pages.Common.Common_Wallpaper">


  <Border Background="Black" x:Name="border" CornerRadius="5" ClipToBounds="True" BorderThickness="2">
    <Border.Styles>
      <Style Selector="Border:pointerover">
        <Setter Property="BorderBrush" Value="Black"/>
      </Style>
      <Style Selector="Border:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.02)"/>
      </Style>
      <Style Selector="Border.Selected">
        <Setter Property="RenderTransform" Value="scale(1)"/>
        <Setter Property="BorderBrush" Value="rgb(88, 101, 242)"/>
      </Style>
    </Border.Styles>
    <Border.Transitions>
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
      </Transitions>
    </Border.Transitions>

    <Grid IsHitTestVisible="False">
      <Border x:Name="img_Icon" IsHitTestVisible="False" CornerRadius="3" ClipToBounds="True">
        <Rectangle x:Name="skeleton_Shimmer" Width="100">
          <Rectangle.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="100%,0%">
              <GradientStop Color="#00111111" Offset="0"/>
              <GradientStop Color="#0c0c0c" Offset="0.3"/>
              <GradientStop Color="#0c0c0c" Offset="0.7"/>
              <GradientStop Color="#00111111" Offset="1"/>
            </LinearGradientBrush>
          </Rectangle.Fill>

          <Rectangle.Styles>
            <Style>
              <Setter Property="Fill" Value="Red"/>
              <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="INFINITE">
                  <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.X" Value="-120"/>
                  </KeyFrame>
                  <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.X" Value="120"/>
                  </KeyFrame>
                </Animation>
              </Style.Animations>
            </Style>
          </Rectangle.Styles>
        </Rectangle>

      </Border>
      <Border VerticalAlignment="Bottom" Height="40" Background="#a9000000" IsHitTestVisible="False">
        <Label x:Name="lbl_Title" Content="Test" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" IsHitTestVisible="False"/>
      </Border>
      <Border Background="#ae000000" x:Name="cont_DownloadStatus">
        <Label HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="lbl_DownloadStatus">Downloading</Label>
      </Border>
      <Border x:Name="cont_ActiveWallpaperStatus" Background="#27AE60" CornerRadius="50" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5" Width="10" Height="10"/>
    </Grid>
  </Border>
</UserControl>

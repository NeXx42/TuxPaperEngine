<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AvaloniaUI.Pages.Common.Common_Tag"
  xmlns:local="clr-namespace:AvaloniaUI.Pages.Common">

  <UserControl.Styles>
    <Style Selector="Border#ctrl">
      <Setter Property="Background" Value="rgb(22, 22, 25)"/>
      <Setter Property="BorderBrush" Value="rgb(46, 46, 56)"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border#ctrl Label">
      <Setter Property="Foreground" Value="rgb(138, 143, 168)"/>
    </Style>

    <Style Selector="local|Common_Tag.active Border#ctrl">
      <Setter Property="Background" Value="rgb(88, 101, 242)"/>
      <Setter Property="BorderBrush" Value="rgb(88, 101, 242)"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="local|Common_Tag.active Border#ctrl Label">
      <Setter Property="Foreground" Value="White"/>
    </Style>
  </UserControl.Styles>

  <Border CornerRadius="20" x:Name="ctrl">
    <Label x:Name="tagName" Content="test" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="12, 4" FontSize="12" />
  </Border>
</UserControl>

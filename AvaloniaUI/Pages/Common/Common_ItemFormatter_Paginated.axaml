<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080" x:Class="AvaloniaUI.Pages.Common.Common_ItemFormatter_Paginated"
  xmlns:Common="clr-namespace:AvaloniaUI.Common">
  <Grid RowDefinitions="*, Auto">

    <WrapPanel x:Name="grid_Content_Container" HorizontalAlignment="Center" ItemSpacing="15" LineSpacing="15" Margin="10"/>
    <Label x:Name="lbl_Content_NetworkResponse" HorizontalAlignment="Center" VerticalAlignment="Center"/>

    <Border Grid.Row="1" BorderBrush="rgb(34, 34, 40)" BorderThickness="0 1 0 0">
      <StackPanel Orientation="Horizontal" Spacing="5" Margin="5" Height="30" HorizontalAlignment="Center">
        <Common:Common_Button Label="1" Width="30" x:Name="btn_Page_1" Classes="Positive2"/>
        <Common:Common_Button Label="2" Width="30" x:Name="btn_Page_2"/>
        <Common:Common_Button Label="4" Width="30" x:Name="btn_Page_3"/>
        <Common:Common_Button Label="5" Width="30" x:Name="btn_Page_4"/>
        <Common:Common_Button Label="5" Width="30" x:Name="btn_Page_5"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

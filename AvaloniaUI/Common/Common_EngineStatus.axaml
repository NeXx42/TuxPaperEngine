<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="AvaloniaUI.Common.Common_EngineStatus">
  <Border Background="rgb(22, 22, 25)" BorderBrush="rgb(46, 46, 56)" BorderThickness="1" CornerRadius="8">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5" Margin="10 0">
      <Border CornerRadius="50" Background="Red" Width="8" Height="8" x:Name="inp_Status"/>
      <Label Content="[Running] wallpaper name" x:Name="lbl_Active"/>
    </StackPanel>
  </Border>
</UserControl>
